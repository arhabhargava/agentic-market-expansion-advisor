# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional: server ──────────────────────────────────────────────────────────
FASTAPI_PORT=8000
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Optional: security ────────────────────────────────────────────────────────
# Restrict CORS to your frontend domain in production.
# Comma-separated list of allowed origins. Defaults to * (all) in dev.
ALLOWED_ORIGINS=*

# Set a secret key to require X-API-Key header on /analyze.
# Leave unset to run without authentication (local dev only).
API_KEY=
